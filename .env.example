# 9Router AI Gateway - Environment Template
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env to version control. Rotate exposed keys immediately.

# Server - Bind to localhost only for security
PORT=20128
HOST=127.0.0.1

# API Authentication - MUST ENABLE FOR PRODUCTION
REQUIRE_API_KEY=false
API_KEY_SECRET=<generate-random-64-char-hex>
JWT_SECRET=<generate-random-64-char-hex>
INITIAL_PASSWORD=<generate-random-16-char-password>

# Provider API Keys - Active Providers
# OpenRouter (Priority 1)
OPENROUTER_API_KEY=

# NVIDIA NIM (Priority 2)
NVIDIA_API_KEY=

# Cloudflare Workers AI (Priority 3)
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_DIR=logs

# Health Check
HEALTH_CHECK_INTERVAL=30000
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_RESET_TIMEOUT=300000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Backup
BACKUP_DIR=backups
BACKUP_RETENTION_DAYS=30

# Security
ENCRYPTION_KEY=
SESSION_TIMEOUT_MINUTES=60
MAX_LOGIN_ATTEMPTS=5

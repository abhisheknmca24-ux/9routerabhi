# 9Router AI Gateway - HARDENED PRODUCTION Configuration
# Copy to .env and fill in real secrets. NEVER commit this file.

# Server
PORT=20128
HOST=127.0.0.1

# API Authentication - MUST BE ENABLED FOR PRODUCTION
REQUIRE_API_KEY=true
API_KEY_SECRET=<generate-random-64-char-hex>
JWT_SECRET=<generate-random-64-char-hex>
INITIAL_PASSWORD=<generate-random-16-char-password>

# Provider API Keys - Active Providers
# OpenRouter (Priority 1)
OPENROUTER_API_KEY=

# NVIDIA NIM (Priority 2)
NVIDIA_API_KEY=

# Cloudflare Workers AI (Priority 3)
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=

# Logging - Production hardened
LOG_LEVEL=warn
LOG_FORMAT=json
LOG_DIR=logs

# Health Check
HEALTH_CHECK_INTERVAL=30000
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_RESET_TIMEOUT=600000

# Rate Limiting - Stricter for production
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# Backup
BACKUP_DIR=backups
BACKUP_RETENTION_DAYS=30

# Security - Production settings
ENCRYPTION_KEY=<generate-random-32-char-hex>
SESSION_TIMEOUT_MINUTES=30
MAX_LOGIN_ATTEMPTS=3
